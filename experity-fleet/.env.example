# Experity Fleet Monitoring Stack — Environment Configuration
# Copy to .env and customize for your environment:  cp .env.example .env

# ─── General ────────────────────────────────────────────────────────
TZ=America/Denver
PUID=1000
PGID=1000

# ─── Experity Targets ──────────────────────────────────────────────
# Your Experity cloud endpoints (used in SmokePing targets)
EXPERITY_APP_HOST=app.experity.com
EXPERITY_LOGIN_HOST=login.experity.com

# ─── Site Gateways (for SmokePing multi-site monitoring) ───────────
# Main site gateway (LAN side of your Meraki MX)
SITE_MAIN_GATEWAY=192.168.1.1
# Remote sites via VPN — set to 0.0.0.0 to skip
SITE2_GATEWAY=10.10.1.1
SITE3_GATEWAY=10.20.1.1
SITE4_GATEWAY=0.0.0.0

# ─── SmokePing ─────────────────────────────────────────────────────
SMOKEPING_PORT=8080

# ─── LibreNMS ──────────────────────────────────────────────────────
LIBRENMS_PORT=8000
LIBRENMS_DB_PASSWORD=changeme-librenms-db-password
LIBRENMS_DB_NAME=librenms
LIBRENMS_DB_USER=librenms
LIBRENMS_DB_HOST=librenms-db
LIBRENMS_APP_URL=http://localhost:8000
# SNMP community string for your Meraki devices
SNMP_COMMUNITY=changeme-snmp-community

# ─── Prometheus ────────────────────────────────────────────────────
PROMETHEUS_PORT=9090
PROMETHEUS_RETENTION=15d
# Prometheus server IP — used for Windows Exporter firewall rules
PROMETHEUS_SERVER_IP=192.168.1.10

# ─── Grafana ───────────────────────────────────────────────────────
GRAFANA_PORT=3000
GRAFANA_ADMIN_PASSWORD=changeme-grafana-admin

# ─── Windows Exporter Targets ──────────────────────────────────────
# Comma-separated list of Windows machines running Prometheus Windows Exporter
# Format: ip:9182 — port 9182 is the Windows Exporter default
# These go into prometheus/file_sd/windows-fleet.json
# For >5 machines, edit prometheus/file_sd/windows-fleet.json directly
WIN_TARGET_1=192.168.1.101:9182
WIN_TARGET_2=192.168.1.102:9182
WIN_TARGET_3=192.168.1.103:9182
