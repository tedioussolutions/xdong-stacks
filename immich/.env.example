# Immich Stack — Environment Variables
# Copy to .env and fill in values before deploying:
#   cp .env.example .env && nano .env

# ── Upload Library ─────────────────────────────────────────────────────────────
# Host path where photos/videos are stored. Use an absolute path to a volume
# with plenty of space (photos/videos accumulate quickly).
# Default uses a relative ./library directory — fine for quick tests, not
# recommended for production.
UPLOAD_LOCATION=./library

# ── Network ────────────────────────────────────────────────────────────────────
# Host port for the Immich web UI and API.
IMMICH_PORT=2283

# ── Database (REQUIRED) ────────────────────────────────────────────────────────
# DB_PASSWORD is required — the stack will not start without it.
# Generate a strong password: openssl rand -base64 32
DB_PASSWORD=changeme

DB_USERNAME=postgres
DB_DATABASE_NAME=immich

# ── Timezone ───────────────────────────────────────────────────────────────────
# Used for correct timestamp display and scheduled task timing.
# List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Denver
