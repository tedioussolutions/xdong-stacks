# Home Assistant Stack — Environment Configuration
# Copy to .env and customize:  cp .env.example .env

# ─── General ────────────────────────────────────────────────────────
TZ=America/Denver

# ─── Home Assistant ─────────────────────────────────────────────────
# Host port for the Home Assistant web UI
HA_PORT=8123

# ─── Mosquitto MQTT (optional — enable with: --profile mqtt) ────────
# Host port for the MQTT broker (used by Zigbee2MQTT, Z-Wave JS, etc.)
MQTT_PORT=1883
