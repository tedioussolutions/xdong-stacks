# Worklab Stack — Environment Configuration
# Copy to .env and customize:  cp .env.example .env

# ─── General ────────────────────────────────────────────────────────
TZ=America/Denver
PUID=1000
PGID=1000

# ─── Caddy ──────────────────────────────────────────────────────────
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ─── Code-Server (VS Code in Browser) ───────────────────────────────
# Password to access the code-server web UI — MUST change from default before deploying
CODE_SERVER_PASSWORD=changeme
# Sudo password for terminal inside code-server — MUST change from default before deploying
CODE_SERVER_SUDO_PASSWORD=changeme

# ─── Meilisearch (Search Engine — shared by Karakeep) ───────────────
# Generate a secure key:  openssl rand -base64 32
MEILI_MASTER_KEY=

# ─── Karakeep (Bookmark Manager) ────────────────────────────────────
# URL where Karakeep is accessed — must match your DNS/hosts setup
KARAKEEP_URL=http://karakeep.work.lab
# Generate a secure secret:  openssl rand -base64 32
KARAKEEP_NEXTAUTH_SECRET=

# ─── PostgreSQL (Database — used by Fluid-Calendar) ─────────────────
POSTGRES_USER=fluid
# Generate a secure password:  openssl rand -base64 16
POSTGRES_PASSWORD=
POSTGRES_DB=fluid_calendar

# ─── Fluid-Calendar ─────────────────────────────────────────────────
# URL where Fluid-Calendar is accessed — must match your DNS/hosts setup
CALENDAR_URL=http://calendar.work.lab
# Generate a secure secret:  openssl rand -base64 32
CALENDAR_NEXTAUTH_SECRET=
