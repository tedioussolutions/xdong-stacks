# Vaultwarden Stack — Environment Configuration
# Copy to .env and fill in your values:
#   cp .env.example .env
#   nano .env

# ── Required ─────────────────────────────────────────────────────────────────

# Full HTTPS URL where Vaultwarden is accessible (no trailing slash)
# Used by the Bitwarden browser extension and mobile apps
# Example: https://vault.yourdomain.com
DOMAIN=https://vault.example.com

# Admin panel token — keep this secret, change before deploying
# Generate a strong token: openssl rand -base64 48
ADMIN_TOKEN=change-me-generate-with-openssl-rand-base64-48

# ── Security ──────────────────────────────────────────────────────────────────

# Disable public registration — invite users via admin panel instead
# Set to true only during initial setup to create your first account
SIGNUPS_ALLOWED=false

# ── Network ───────────────────────────────────────────────────────────────────

# Host port Vaultwarden listens on (mapped to container port 80)
# Your reverse proxy should forward HTTPS traffic to this port
VAULTWARDEN_PORT=8080

# ── Permissions ───────────────────────────────────────────────────────────────

# User/group ID for file ownership in mounted volumes
# Run: id -u && id -g  to find your values
PUID=1000
PGID=1000
