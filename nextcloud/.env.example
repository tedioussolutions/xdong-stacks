# Nextcloud AIO Stack — Environment Variables
# Copy this file to .env and edit values before deploying:
#   cp .env.example .env && nano .env

# ── Data Storage ────────────────────────────────────────────────────────────

# Where Nextcloud stores user files on the Docker host.
# Default: a named Docker volume (managed by Docker, easiest to get started).
# Override with an absolute host path to store files on a specific disk:
#   NEXTCLOUD_DATADIR=/mnt/data/nextcloud
NEXTCLOUD_DATADIR=nextcloud_aio_nextcloud_datadir

# ── Ports ────────────────────────────────────────────────────────────────────

# Port the AIO mastercontainer dashboard listens on (HTTP API + first-run wizard).
# Access at http://localhost:NEXTCLOUD_AIO_PORT after starting the stack.
NEXTCLOUD_AIO_PORT=8080

# Port the Nextcloud Apache frontend (spawned by AIO) binds on the host.
# Point your reverse proxy at this port. Must be open in your firewall.
APACHE_PORT=11000

# ── Nextcloud ────────────────────────────────────────────────────────────────

# Comma-separated list of domains or IPs that Nextcloud will accept requests from.
# Add every hostname/IP users will access Nextcloud through (including reverse proxy domain).
# Example: NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.example.com,192.168.1.100
NEXTCLOUD_TRUSTED_DOMAINS=nextcloud.local

# ── System ───────────────────────────────────────────────────────────────────

# Timezone for all AIO-managed sub-containers.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Denver

# User and group ID that file operations run as inside Nextcloud containers.
# Match these to your host user (run `id` to check) to avoid permission issues.
PUID=1000
PGID=1000
