# Jellyfin Media Server Stack — Environment Configuration
# Copy to .env and customize:  cp .env.example .env

# ─── Permissions ────────────────────────────────────────────────────
# Run `id` in your terminal to find your user/group IDs.
# Jellyfin will read/write config and cache as this user.
PUID=1000
PGID=1000

# ─── Media Library ──────────────────────────────────────────────────
# Absolute path to your media directory on the host.
# Mounted read-only inside the container at /media.
# Example: /mnt/nas/media  or  /home/user/Videos
MEDIA_PATH=/srv/media

# ─── Network ────────────────────────────────────────────────────────
# Host port Jellyfin listens on. Change if 8096 is already in use.
JELLYFIN_PORT=8096

# ─── Server URL ─────────────────────────────────────────────────────
# Public URL Jellyfin advertises to clients (used for remote playback).
# Set this to your LAN IP or domain if accessing from other devices.
# Example: http://192.168.1.10:8096  or  https://jellyfin.example.com
JELLYFIN_URL=http://localhost:8096
