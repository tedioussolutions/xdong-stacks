# Caddy Standalone Reverse Proxy — Environment Variables
# Copy to .env and fill in your values:
#   cp .env.example .env

# ── Ports ────────────────────────────────────────────────────────────────────
# Change only if ports 80/443 are already taken on this machine.
HTTP_PORT=80
HTTPS_PORT=443

# ── Let's Encrypt ─────────────────────────────────────────────────────────────
# Required for automatic HTTPS. Uncomment the email line in Caddyfile as well.
# EMAIL=your@email.com
