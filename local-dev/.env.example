# local-dev Stack — Environment Configuration
# Copy to .env and customize:  cp .env.example .env
#
# Secret generation commands:
#   32-char hex:    openssl rand -hex 16
#   64-char hex:    openssl rand -hex 32
#   Base64 (44ch):  openssl rand -base64 32

# ─── General ────────────────────────────────────────────────────────────────
TZ=America/Denver
PUID=1000
PGID=1000

# ─── Postgres (shared instance) ─────────────────────────────────────────────
# The superuser for the shared Postgres instance.
# Each service gets its own lower-privileged user created by the init SQL script.
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-postgres

# Per-service database passwords — must match values in 01-create-databases.sql
# If you change these after first start, you must also update the sql file
# and wipe the postgres volume: docker compose down -v
FORGEJO_DB_PASSWORD=change-me-forgejo
N8N_DB_PASSWORD=change-me-n8n
BYTEBASE_DB_PASSWORD=change-me-bytebase
ACTIVEPIECES_DB_PASSWORD=change-me-activepieces

# ─── Code-Server ────────────────────────────────────────────────────────────
CODE_SERVER_PASSWORD=change-me-code-server
# Uncomment to enable sudo access inside the VS Code terminal
# CODE_SERVER_SUDO_PASSWORD=change-me-sudo

# ─── Meilisearch ────────────────────────────────────────────────────────────
# Minimum 16 bytes. Generate: openssl rand -hex 16
MEILI_MASTER_KEY=change-me-meilisearch-master-key

# ─── Qdrant ─────────────────────────────────────────────────────────────────
# Leave empty to disable API key authentication (default for local dev)
QDRANT_API_KEY=

# ─── n8n ────────────────────────────────────────────────────────────────────
N8N_HOST=localhost
# Webhook URL — used for external webhook triggers. Must be accessible from internet
# for webhook-based triggers to work. Update if exposing n8n via tunnel/reverse proxy.
N8N_WEBHOOK_URL=http://localhost:5678

# ─── Open WebUI ─────────────────────────────────────────────────────────────
# URL of your local Ollama instance. Uses host.docker.internal to reach the
# Docker host. Change to http://<your-host-ip>:11434 if host-gateway isn't supported.
OLLAMA_BASE_URL=http://host.docker.internal:11434
# Generate: openssl rand -hex 32
OPEN_WEBUI_SECRET_KEY=change-me-openwebui-secret

# ─── Activepieces ────────────────────────────────────────────────────────────
# Both must be exactly 32 hex characters (16 bytes).
# Generate: openssl rand -hex 16
AP_ENCRYPTION_KEY=change-me-ap-encryption-key-32ch
AP_JWT_SECRET=change-me-ap-jwt-secret-32chars00

# ─── AnythingLLM ─────────────────────────────────────────────────────────────
# JWT signing secret. Generate: openssl rand -base64 32
ANYTHINGLLM_JWT_SECRET=change-me-anythingllm-jwt-secret
# Password to access the UI (AUTH_TOKEN). Set to empty string to disable auth.
ANYTHINGLLM_PASSWORD=change-me-anythingllm-password
