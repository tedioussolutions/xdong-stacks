# Local Homelab Stack — Environment Configuration
# Copy to .env and customize:  cp .env.example .env
#
# ⚠️  Arcane requires generated secrets. Run this command TWICE (once per var):
#   docker run --rm ghcr.io/getarcaneapp/arcane:latest /app/arcane generate secret

# ─── General ────────────────────────────────────────────────────────
TZ=America/Denver
PUID=1000
PGID=1000

# ─── Caddy ──────────────────────────────────────────────────────────
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ─── Arcane (Docker Management UI) ──────────────────────────────────
# URL Arcane uses to construct links (must match how you access it)
ARCANE_APP_URL=http://arcane.local
# Generate these secrets (run command above twice):
ARCANE_ENCRYPTION_KEY=changeme-run-arcane-generate-secret
ARCANE_JWT_SECRET=changeme-run-arcane-generate-secret
# Directory where compose stacks live — MUST use identical path inside/outside container
# Arcane uses STACKS_DIRECTORY env var to discover stacks; STACKS_DIR sets the volume path
STACKS_DIR=/opt/stacks

# ─── n8n (Workflow Automation) ───────────────────────────────────────
N8N_HOST=n8n.local
N8N_PROTOCOL=http
# Webhook URL — must match how n8n is accessed externally (include trailing slash)
N8N_WEBHOOK_URL=http://n8n.local/
