# Local Homelab Stack — Environment Configuration
# Copy to .env and customize:  cp .env.example .env

# ─── General ────────────────────────────────────────────────────────
TZ=America/Denver
PUID=1000
PGID=1000

# ─── Caddy ──────────────────────────────────────────────────────────
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443

# ─── n8n (Workflow Automation) ───────────────────────────────────────
N8N_HOST=n8n.local
N8N_PROTOCOL=http
# Webhook URL — must match how n8n is accessed externally (include trailing slash)
N8N_WEBHOOK_URL=http://n8n.local/
