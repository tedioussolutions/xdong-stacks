# AdGuard Home Stack — Environment Variables
# Copy to .env and customize:  cp .env.example .env

# ── Ports ────────────────────────────────────────────────────────────────────
# Web UI (initial setup wizard and management dashboard)
ADGUARD_WEB_PORT=3000

# DNS — plain DNS queries (TCP + UDP). Change if 53 is already in use.
# NOTE: Port 53 is held by systemd-resolved on Ubuntu 18.04+ and Debian 12+.
# Run validate.sh to detect the conflict. See README.md for the fix.
ADGUARD_DNS_PORT=53

# DNS-over-HTTPS (DoH) — encrypted DNS for browsers and clients that support it
ADGUARD_HTTPS_PORT=443

# DNS-over-TLS (DoT) — encrypted DNS for mobile devices and modern routers
ADGUARD_DNS_QUIC_PORT=853

# ── Timezone ─────────────────────────────────────────────────────────────────
# Used for query log timestamps in the web UI.
# List: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Denver
