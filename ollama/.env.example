# Ollama + Open WebUI Stack — Environment Configuration
# Copy to .env and customize:  cp .env.example .env

# ── Ports ─────────────────────────────────────────────────────────────────

# Host port for the Ollama API (default: 11434)
# Change if the port is already in use on your host.
OLLAMA_PORT=11434

# Host port for the Open WebUI browser interface (default: 3000)
# Change if the port is already in use on your host.
WEBUI_PORT=3000

# ── Timezone ──────────────────────────────────────────────────────────────

# Timezone for containers — affects log timestamps.
# Full list: https://en.wikipedia.org/wiki/List_of_tz_database_time_zones
TZ=America/Denver

# ── Optional: External Model Directory ────────────────────────────────────

# Uncomment to store Ollama models on a host path instead of a named volume.
# Useful when pointing at an existing model cache or a large data drive.
# Example: /mnt/data/ollama/models  or  /home/user/.ollama
# OLLAMA_MODELS=/path/to/models
